<%- include("Navbar.ejs") %>

<div class="container">
    <div class="row bg-white p-2 rounded">
        <div class="col-md-12">
            <h1 class="fw-bold">Product List</h1>
        </div>
    </div>

    <div class="row bg-white p-2 mt-3 rounded">
        <div class="col-md-12">
            <table class="table table-bordered">
                    <tr>
                        <th>Action</th>
                        <th>Sr.No</th>
                        <th>Product Name</th>
                        <th>Company</th>
                        <th>Tag</th>
                        <th>Color</th>
                        <th>Price-Range</th>  
                    </tr>


                    <% product_list.map(function(val,i){ %>

                        <tr>
                            <td>
                                <a href="/admin/product_delete/<%=val.product_id%>"><button class="btn btn-danger"><i class="fa-solid fa-trash"></i></button></a>
                                <a href="/admin/product_edit/<%=val.product_id%>"><button class="btn btn-primary"><i class="fa-solid fa-pen-to-square"></i></button></a>
                                <a href="/admin/product_info/<%=val.product_id%>"><button class="btn btn-warning"><i class="fa-solid fa-eye"></i></button></a>
                            </td>
                            <td><%=i+1%></td>
                            <td><%=val.product_name%></td>
                            <td><%=val.Product_company%></td>
                            <td><%=val.product_tag%></td>
                            <td><%=val.product_color%></td>
                            <td><%=val.price%>-<%=val.product_duplicate_price%></td>
                        </tr>

                   <%  }) %>


            </table>
        </div>
    </div>
</div>

<%- include("Footer.ejs") %>