<%-include("Navbar.ejs")%>





<div id="prit_area" class="invoice">

    <style>
    body {
        font-family: Arial, sans-serif;
        background: #f5f5f5;
        margin: 0;
        padding: 20px;
    }

    .invoice {
        background: #fff;
        padding: 30px;
        max-width: 900px;
        margin: auto;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        border-radius: 8px;
        border: 1px solid black;
    }

    .header {
        display: flex;
        justify-content: space-between;
    }

    .title {
        font-size: 28px;
        font-weight: bold;
    }

    .payment-details {
        text-align: right;
        font-size: 14px;
    }

    .info {
        margin-top: 20px;
        line-height: 1.8;
    }

    .divider {
        border-top: 1px solid #ddd;
        margin: 20px 0;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
    }

    .table th {
        text-align: left;
        color: #777;
        padding-bottom: 10px;
    }

    .table td {
        padding: 10px 0;
    }

    .table .right {
        text-align: right;
    }

    .item-title {
        font-weight: bold;
    }

    .item-desc {
        font-size: 14px;
        color: #777;
    }

    .total {
        text-align: right;
        margin-top: 20px;
        font-size: 18px;
        font-weight: bold;
    }
</style>

    <div class="header">
        <div class="title">ULTRAS</div>

        <div class="payment-details">
            <strong>Payment Details</strong><br>
            Bank Name: 012345678901<br>
            Account Number: 012345678901<br>
            SWIFT Code: SWITCH012345678CODE<br>
            V.A.T Reg #: VAT5678901CODE
        </div>
    </div>

    <div class="info">
        <strong>First Name:</strong> Datta shrikant padre <br>
        <strong>Customer Mobile:</strong> 07249329153 <br>
        <strong>Address:</strong> Maharashtra, Nagar, Ahmednagar, Nannaj, 414001 <br>
        <strong>DOB:</strong> YYYY/MM/DD
    </div>

    <div class="divider"></div>

    <table class="table">
        <thead>
            <tr>
                <th>Item Name</th>
                <th class="right">Quantity</th>
                <th class="right">Rate</th>
                <th class="right">Total Price</th>
            </tr>
        </thead>

        <tbody>
            <tr>
                <td>
                    <div class="item-title">Unique side and front panel design</div>
                    <div class="item-desc">
                        Lorem ipsum dolor sit amet, consectetur adipiscing elit.
                    </div>
                </td>
                <td class="right">2</td>
                <td class="right">$20.00</td>
                <td class="right">$23.78</td>
            </tr>
        </tbody>
    </table>

    <div class="total">
        Grand Total: $23.78
    </div>

</div>

<div class="container">
    <div class="row">
        <div class="col-md-12 text-center">
            <button onclick="printing()">Print</button>
        </div>
    </div>
</div>

<script>
function printing() {
    var printContents = document.getElementById("prit_area").innerHTML;
    var originalContents = document.body.innerHTML;

    document.body.innerHTML = printContents;
    window.print();
    document.body.innerHTML = originalContents;
}
</script>


